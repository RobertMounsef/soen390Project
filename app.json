{
  "expo": {
    "name": "Campus Guide",
    "slug": "campus-guide",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "campusguide",
    "icon": "./assets/images/logo192.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/logo512.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": true,
      "bundleIdentifier": "com.debuggingdemons.campusguide"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo192.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.debuggingdemons.campusguide",
      "config": {
        "googleMaps": {
          "apiKey": "${GOOGLE_MAPS_API_KEY}"
        }
      }
    },
    "plugins": [
      "expo-dev-client",
      "expo-asset",
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ]
  }
}
